# ================================================================
# EstimateOS Backend — Environment Variables
# ================================================================
# USAGE:
#   cp .env.example .env
#   Edit OPENAI_API_KEY with your key from https://platform.openai.com
#
# DOCKER COMPOSE (recommended): keep DB_HOST=postgres, REDIS_HOST=redis, etc.
# RUNNING LOCALLY (no Docker):  change to localhost for all service hosts
# ================================================================

NODE_ENV=development
PORT=3000
CORS_ORIGINS=http://localhost:3001,http://localhost:3000
FRONTEND_URL=http://localhost:3001

# JWT — change JWT_SECRET to a random 64-char string in production
JWT_SECRET=dev_CHANGE_ME_use_openssl_rand_base64_64
JWT_EXPIRY=15m
REFRESH_TOKEN_DAYS=30

# ── Database (Docker: DB_HOST=postgres) ──────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=estimateos
DB_USERNAME=estimateos
DB_PASSWORD=changeme
DB_SSL=false

# ── Redis (Docker: REDIS_HOST=redis) ─────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# ── OpenAI — PUT YOUR KEY HERE ── ───────────────────────────────
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY_HERE
OPENAI_PRIMARY_MODEL=gpt-4o
OPENAI_FALLBACK_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_MAX_TOKENS=8000
OPENAI_TEMPERATURE=0.1

# ── Qdrant (Docker: QDRANT_HOST=qdrant) ──────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=

# ── MinIO (Docker: MINIO_ENDPOINT=minio) ─────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme
MINIO_USE_SSL=false
MINIO_REGION=us-east-1

# ── Email (leave blank to skip email in dev) ─────────────────────
# Free testing: https://mailtrap.io
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@estimateos.com
EMAIL_SECURE=false

# ── Misc ──────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=100
QUEUE_CONCURRENCY=3
